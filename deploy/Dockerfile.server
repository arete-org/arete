# === Build stage ===
FROM node:22-slim AS builder

WORKDIR /app
ENV NODE_ENV=production

RUN corepack enable && corepack prepare pnpm@10.27.0 --activate

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

COPY tsconfig.json ./tsconfig.json
COPY package.json pnpm-workspace.yaml ./
COPY packages/agent-runtime/package.json packages/agent-runtime/tsconfig.json packages/agent-runtime/
COPY packages/api-client/package.json packages/api-client/tsconfig.json packages/api-client/
COPY packages/backend/package.json packages/backend/tsconfig.json packages/backend/
COPY packages/config-spec/package.json packages/config-spec/tsconfig.json packages/config-spec/
COPY packages/contracts/package.json packages/contracts/tsconfig.json packages/contracts/
COPY packages/discord-bot/package.json packages/discord-bot/tsconfig.json packages/discord-bot/
COPY packages/prompts/package.json packages/prompts/tsconfig.json packages/prompts/
COPY packages/web/package.json packages/web/tsconfig.json packages/web/

COPY pnpm-lock.yaml* ./
RUN --mount=type=cache,id=footnote-pnpm-store,target=/pnpm/store \
  pnpm install --frozen-lockfile --prod=false --store-dir /pnpm/store

COPY packages/agent-runtime/src/ packages/agent-runtime/src/
COPY packages/api-client/src/ packages/api-client/src/
COPY packages/backend/src/ packages/backend/src/
COPY packages/config-spec/src/ packages/config-spec/src/
COPY packages/contracts/src/ packages/contracts/src/
COPY packages/discord-bot/ packages/discord-bot/
COPY packages/prompts/src/ packages/prompts/src/
COPY packages/web/ packages/web/

RUN pnpm --filter @footnote/contracts run build \
  && pnpm --filter @footnote/config-spec run build \
  && pnpm --filter @footnote/prompts run build \
  && pnpm --filter @footnote/api-client run build \
  && pnpm --filter @footnote/agent-runtime run build \
  && pnpm --filter @footnote/backend run build \
  && pnpm --filter @footnote/discord-bot run build \
  && pnpm --filter @footnote/web run build

FROM litestream/litestream:0.5 AS litestream

# === Runtime stage ===
FROM node:22-slim

WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/node_modules /app/node_modules
COPY --from=builder /app/packages /app/packages
COPY --from=litestream /usr/local/bin/litestream /usr/local/bin/litestream
COPY deploy/litestream.yml /etc/litestream.yml
COPY deploy/backend-entrypoint.sh /usr/local/bin/backend-entrypoint.sh
COPY deploy/server-entrypoint.sh /usr/local/bin/server-entrypoint.sh
COPY deploy/traceTokenResolver.mjs /usr/local/bin/trace-token-resolver.mjs
RUN chmod +x /usr/local/bin/backend-entrypoint.sh /usr/local/bin/server-entrypoint.sh /usr/local/bin/trace-token-resolver.mjs

EXPOSE 3000
CMD ["/usr/local/bin/server-entrypoint.sh"]
