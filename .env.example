##############################################################################
# 00) START HERE (MINIMUM TO RUN)
##############################################################################

# Discord bot token used to authenticate a local Discord persona node.
# string
# On Fly deploy: Discord bot machine.
DISCORD_TOKEN=

# Discord application client ID for a local Discord persona node.
# string
# On Fly deploy: Discord bot machine.
DISCORD_CLIENT_ID=

# Preferred comma-separated Discord guild IDs used for local Discord node command registration.
# comma-separated values
# On Fly deploy: Discord bot machine.
DISCORD_GUILD_IDS=

# Primary Discord guild ID for local Discord node command registration.
# string
# On Fly deploy: Discord bot machine.
DISCORD_GUILD_ID=

# Developer Discord user ID used for privileged local Discord node actions.
# string
# On Fly deploy: Discord bot machine.
DISCORD_USER_ID=

# OpenAI API key used when OpenAI-backed profiles or OpenAI-only routes are enabled.
# string
OPENAI_API_KEY=

# Base URL for Ollama inference (local daemon or Ollama cloud endpoint).
# string
OLLAMA_BASE_URL=

# Optional Ollama API key for cloud-hosted endpoints that require auth.
# string
OLLAMA_API_KEY=

# When true, allows model profiles to target local Ollama hosts (localhost/loopback).
# `true` or `false`
OLLAMA_LOCAL_INFERENCE_ENABLED=false

# Note: Canonical server startup does not require provider config. Without OPENAI_API_KEY or OLLAMA_BASE_URL,
# model-dependent features return setup-required errors until a provider is configured.

##############################################################################
# 01) CORE RUNTIME
##############################################################################

# Node runtime mode used for production/development branching.
# `production`, `development`, `test`
NODE_ENV=development

# Directory where rotating log files are written.
# string
LOG_DIR=logs

# Logger verbosity level.
# `error`, `warn`, `info`, `http`, `verbose`, `debug`, `silly`
LOG_LEVEL=info

# Fly app name used to derive internal or public service URLs.
# string
FLY_APP_NAME=

# Base URL used for bot-to-backend requests and the web dev proxy.
# string
# On Fly deploy: server app.
BACKEND_BASE_URL=http://localhost:3000

# Optional path to local Discord node config YAML used by server supervisor.
# string
LOCAL_DISCORD_NODES_CONFIG_PATH=/data/config/local-discord-nodes.yaml

# Base URL for the web app that hosts trace and share pages.
# string
# On Fly deploy: server app.
WEB_BASE_URL=http://localhost:8080

# Local webhook listener port used by the Discord bot.
# integer
# On Fly deploy: Discord bot machine.
WEBHOOK_PORT=3000

# Timeout budget for bot requests sent to the backend.
# integer
# On Fly deploy: Discord bot machine.
BACKEND_REQUEST_TIMEOUT_MS=180000

# Directory used for backend persistent data on disk.
# string
DATA_DIR=/data

# Host/interface the backend binds to.
# string
HOST=::

# Port the backend listens on.
# integer
PORT=3000

##############################################################################
# 02) DISCORD BOT IDENTITY AND ACCESS
##############################################################################

# Comma-separated Discord user IDs allowed to review incidents through Discord commands.
# comma-separated values
# On Fly deploy: Discord bot machine.
DISCORD_SUPERUSER_IDS=

# Stable profile identifier for the bot runtime persona overlay.
# string
# On Fly deploy: Discord bot machine.
BOT_PROFILE_ID=footnote

# Human-readable profile name for bot runtime persona overlay.
# string
# On Fly deploy: Discord bot machine.
BOT_PROFILE_DISPLAY_NAME=Footnote

# Optional inline prompt overlay text for bot profile behavior.
# string
# On Fly deploy: Discord bot machine.
BOT_PROFILE_PROMPT_OVERLAY=

# Optional path to a text file containing bot profile prompt overlay instructions.
# string
# On Fly deploy: Discord bot machine.
BOT_PROFILE_PROMPT_OVERLAY_PATH=

# Optional comma-separated plain-text aliases that count as mentions for this bot profile.
# comma-separated values
# On Fly deploy: Discord bot machine.
BOT_PROFILE_MENTION_ALIASES=

# Optional path to a YAML file with shared prompt overrides for backend and Discord runtimes.
# string
PROMPT_CONFIG_PATH=

##############################################################################
# 03) PROVIDER SETUP (OPENAI/OLLAMA)
##############################################################################

# Default model used by backend chat flows.
# string
DEFAULT_MODEL=gpt-5-mini

# Optional path to a YAML model profile catalog used for backend model routing.
# string
MODEL_PROFILE_CATALOG_PATH=

# Default model profile ID used when backend model selection input is empty or invalid.
# string
DEFAULT_PROFILE_ID=openai-text-medium

# Model profile ID used for planner calls so planner and response profiles can differ.
# string
PLANNER_PROFILE_ID=openai-text-fast

# When true, planner execution uses structured function-calling output when available.
# `true` or `false`
PLANNER_STRUCTURED_OUTPUT_ENABLED=true

# When true, planner falls back to text JSON compatibility parsing when structured planner execution fails.
# `true` or `false`
PLANNER_ALLOW_TEXT_JSON_COMPATIBILITY_FALLBACK=false

# Default reasoning effort for backend chat flows.
# `low`, `medium`, `high`
DEFAULT_REASONING_EFFORT=low

# Default verbosity for backend chat flows.
# `low`, `medium`, `high`
DEFAULT_VERBOSITY=low

# Timeout budget for backend OpenAI requests.
# integer
OPENAI_REQUEST_TIMEOUT_MS=180000

##############################################################################
# 04) SECURITY AND SECRETS
##############################################################################

# HMAC secret used to pseudonymize stored identifiers.
# string
INCIDENT_PSEUDONYMIZATION_SECRET=

# Shared secret for trusted trace ingestion requests.
# string
TRACE_API_TOKEN=

# Optional path to trace API token file when TRACE_API_TOKEN is unset.
# string
TRACE_API_TOKEN_FILE=

# Shared secret for trusted reflect callers.
# string
REFLECT_SERVICE_TOKEN=

# Cloudflare Turnstile secret key.
# string
TURNSTILE_SECRET_KEY=

# GitHub webhook signing secret.
# string
GITHUB_WEBHOOK_SECRET=

##############################################################################
# 05) WEB/NETWORK AND CORS
##############################################################################

# Enables Express trust proxy behavior for web requests.
# `true` or `false`
WEB_TRUST_PROXY=false

# CORS allowlist for web origins.
# comma-separated values
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,https://ai.jordanmakes.dev

# CSP frame-ancestors allowlist used by backend responses and web dev tooling.
# comma-separated values
FRAME_ANCESTORS='self',https://ai.jordanmakes.dev,http://localhost:8080,http://localhost:3000

# Cloudflare Turnstile site key returned to the web client.
# string
TURNSTILE_SITE_KEY=

# Optional allowlist of hostnames accepted in Turnstile responses.
# comma-separated values
TURNSTILE_ALLOWED_HOSTNAMES=

##############################################################################
# 06) STORAGE PATHS
##############################################################################

# SQLite path for provenance trace storage.
# string
PROVENANCE_SQLITE_PATH=/data/provenance.db

# SQLite path for incident storage.
# string
INCIDENT_SQLITE_PATH=/data/incidents.db

# S3-compatible replica URL used by Litestream for SQLite backup replication.
# string
LITESTREAM_REPLICA_URL=

##############################################################################
# 07) RATE LIMITS
##############################################################################

# Enables per-user Discord rate limiting.
# `true` or `false`
# On Fly deploy: Discord bot machine.
RATE_LIMIT_USER=true

# Maximum bot-handled messages per user in the rate window.
# integer
# On Fly deploy: Discord bot machine.
USER_RATE_LIMIT=5

# Per-user Discord rate-limit window in milliseconds.
# integer
# On Fly deploy: Discord bot machine.
USER_RATE_WINDOW_MS=60000

# Enables per-channel Discord rate limiting.
# `true` or `false`
# On Fly deploy: Discord bot machine.
RATE_LIMIT_CHANNEL=true

# Maximum bot-handled messages per channel in the rate window.
# integer
# On Fly deploy: Discord bot machine.
CHANNEL_RATE_LIMIT=10

# Per-channel Discord rate-limit window in milliseconds.
# integer
# On Fly deploy: Discord bot machine.
CHANNEL_RATE_WINDOW_MS=60000

# Enables per-guild Discord rate limiting.
# `true` or `false`
# On Fly deploy: Discord bot machine.
RATE_LIMIT_GUILD=true

# Maximum bot-handled messages per guild in the rate window.
# integer
# On Fly deploy: Discord bot machine.
GUILD_RATE_LIMIT=20

# Per-guild Discord rate-limit window in milliseconds.
# integer
# On Fly deploy: Discord bot machine.
GUILD_RATE_WINDOW_MS=60000

# Public web API rate limit per IP.
# integer
WEB_API_RATE_LIMIT_IP=3

# Window for the public web API per-IP rate limit.
# integer
WEB_API_RATE_LIMIT_IP_WINDOW_MS=60000

# Public web API rate limit per session.
# integer
WEB_API_RATE_LIMIT_SESSION=5

# Window for the public web API per-session rate limit.
# integer
WEB_API_RATE_LIMIT_SESSION_WINDOW_MS=60000

# Trusted reflect service rate limit.
# integer
REFLECT_SERVICE_RATE_LIMIT=30

# Window for the trusted reflect service rate limit.
# integer
REFLECT_SERVICE_RATE_LIMIT_WINDOW_MS=60000

# Trace API write rate limit.
# integer
TRACE_API_RATE_LIMIT=10

# Window for the trace API write rate limit.
# integer
TRACE_API_RATE_LIMIT_WINDOW_MS=60000

# Maximum request body size for /api/chat.
# integer
REFLECT_API_MAX_BODY_BYTES=262144

# Maximum request body size for /api/traces.
# integer
TRACE_API_MAX_BODY_BYTES=262144

# Maximum request body size for the GitHub webhook endpoint.
# integer
GITHUB_WEBHOOK_MAX_BODY_BYTES=262144

##############################################################################
# 08) REALTIME VOICE
##############################################################################

# Default model used by realtime voice sessions.
# `gpt-realtime-1.5`, `gpt-realtime`, `gpt-realtime-mini`, `gpt-4o-realtime-preview`, `gpt-4o-mini-realtime-preview`
REALTIME_DEFAULT_MODEL=gpt-realtime-mini

# Default voice used by realtime voice sessions.
# `alloy`, `ash`, `ballad`, `coral`, `echo`, `fable`, `nova`, `onyx`, `sage`, `shimmer`
REALTIME_DEFAULT_VOICE=echo

# Turn detection strategy for realtime voice sessions (server_vad or semantic_vad).
# `server_vad`, `semantic_vad`
REALTIME_TURN_DETECTION=server_vad

# Optional server VAD threshold (0-1). Leave unset to use provider defaults.
# number
# On Fly deploy: Discord bot machine.
REALTIME_VAD_THRESHOLD=

# Optional server VAD silence duration in milliseconds. Leave unset to use provider defaults.
# integer
# On Fly deploy: Discord bot machine.
REALTIME_VAD_SILENCE_MS=

# Optional server VAD prefix padding in milliseconds. Leave unset to use provider defaults.
# integer
# On Fly deploy: Discord bot machine.
REALTIME_VAD_PREFIX_MS=

# When true, the provider auto-creates a response after each detected turn.
# `true` or `false`
# On Fly deploy: Discord bot machine.
REALTIME_VAD_CREATE_RESPONSE=

# When true, allow new speech to interrupt an in-flight response.
# `true` or `false`
# On Fly deploy: Discord bot machine.
REALTIME_VAD_INTERRUPT_RESPONSE=

# Optional semantic VAD eagerness (low|medium|high|auto). Leave unset to use provider defaults.
# `low`, `medium`, `high`, `auto`
# On Fly deploy: Discord bot machine.
REALTIME_VAD_EAGERNESS=

# Greeting text sent when a realtime voice session starts. Supports {bot} placeholder.
# string
# On Fly deploy: Discord bot machine.
REALTIME_GREETING="Hey, {bot} here."

##############################################################################
# 09) SEARCH/CONTEXT INTEGRATIONS
##############################################################################

# Chat workflow mode selection used by backend orchestration.
# `balanced`, `grounded`
CHAT_WORKFLOW_MODE_ID=grounded

# Enables backend chat review-loop orchestration for iterative review cycles.
# `true` or `false`
CHAT_REVIEW_LOOP_ENABLED=false

# Maximum number of backend review-loop iterations when review loop is enabled.
# integer
CHAT_REVIEW_LOOP_MAX_ITERATIONS=2

# Maximum total review-loop duration in milliseconds when review loop is enabled.
# integer
CHAT_REVIEW_LOOP_MAX_DURATION_MS=15000

# Maximum manual maxReviewCycles override accepted from /api/chat requests before backend clamping.
# integer
CHAT_MAX_REQUEST_REVIEW_CYCLES=7

# Enables web-search context integration execution in chat workflow orchestration.
# `true` or `false`
CHAT_CONTEXT_WEB_SEARCH_ENABLED=true

# Ordered provider fallback list for web-search context integration (`searxng`, `brave`, `serpapi`).
# comma-separated values
CHAT_CONTEXT_WEB_SEARCH_PROVIDER_PRIORITY=searxng,brave,serpapi

# Base URL for SearXNG web-search provider.
# string
CHAT_CONTEXT_WEB_SEARCH_SEARXNG_BASE_URL=

# Brave API key for web-search provider.
# string
CHAT_CONTEXT_WEB_SEARCH_BRAVE_API_KEY=

# SerpAPI key for web-search provider.
# string
CHAT_CONTEXT_WEB_SEARCH_SERPAPI_API_KEY=

# Optional SerpAPI engine override for web search (for example `google`).
# string
CHAT_CONTEXT_WEB_SEARCH_SERPAPI_ENGINE=

# Optional SerpAPI country hint (`gl`) for web-search requests.
# string
CHAT_CONTEXT_WEB_SEARCH_SERPAPI_GL=

# Optional SerpAPI language hint (`hl`) for web-search requests.
# string
CHAT_CONTEXT_WEB_SEARCH_SERPAPI_HL=

# Timeout budget for each web-search provider HTTP request in milliseconds.
# integer
CHAT_CONTEXT_WEB_SEARCH_PROVIDER_TIMEOUT_MS=12000

# Maximum number of normalized web-search results retained per provider attempt.
# integer
CHAT_CONTEXT_WEB_SEARCH_MAX_RESULTS=6

# Enables optional OpenAI-native follow-up search from web-search context-step hints.
# `true` or `false`
CHAT_CONTEXT_WEB_SEARCH_OPENAI_NATIVE_FROM_HINTS_ENABLED=true

# Enables reverse-image context integration execution in chat workflow orchestration.
# `true` or `false`
CHAT_CONTEXT_REVERSE_IMAGE_SEARCH_ENABLED=true

# Automatically requests reverse-image context integration when image attachments are present.
# `true` or `false`
CHAT_CONTEXT_REVERSE_IMAGE_SEARCH_AUTORUN=true

# Maximum number of reverse-image source matches surfaced per image attachment.
# integer
CHAT_CONTEXT_REVERSE_IMAGE_SEARCH_MAX_MATCHES_PER_IMAGE=2

# Reverse-image provider mode (`none` or `serpapi`). `none` keeps the integration fail-open unavailable.
# `none`, `serpapi`
CHAT_CONTEXT_REVERSE_IMAGE_SEARCH_PROVIDER=none

# SerpAPI key used when reverse-image provider mode is set to `serpapi`.
# string
CHAT_CONTEXT_REVERSE_IMAGE_SEARCH_SERPAPI_API_KEY=

# Timeout budget for reverse-image provider HTTP requests in milliseconds.
# integer
CHAT_CONTEXT_REVERSE_IMAGE_SEARCH_PROVIDER_TIMEOUT_MS=12000

##############################################################################
# 10) ALERTS AND NOTIFICATIONS
##############################################################################

# Enable incident/breaker alerts to a Discord channel target.
# `true` or `false`
INCIDENT_ALERTS_DISCORD_ENABLED=false

# Discord bot token used to send incident alerts into the configured channel.
# string
INCIDENT_ALERTS_DISCORD_BOT_TOKEN=

# Discord channel ID used as the incident alert destination.
# string
INCIDENT_ALERTS_DISCORD_CHANNEL_ID=

# Optional Discord role ID to mention in incident alert messages.
# string
INCIDENT_ALERTS_DISCORD_ROLE_ID=

# Enable incident/breaker alerts to the configured admin email recipients.
# `true` or `false`
INCIDENT_ALERTS_EMAIL_ENABLED=false

# SMTP host for admin email alert delivery.
# string
INCIDENT_ALERTS_EMAIL_SMTP_HOST=

# SMTP port for admin email alert delivery.
# integer
INCIDENT_ALERTS_EMAIL_SMTP_PORT=587

# When true, uses implicit TLS for SMTP alert delivery (typically port 465).
# `true` or `false`
INCIDENT_ALERTS_EMAIL_SMTP_SECURE=false

# Optional SMTP username for authenticated admin email alert delivery.
# string
INCIDENT_ALERTS_EMAIL_SMTP_USERNAME=

# Optional SMTP password for authenticated admin email alert delivery.
# string
INCIDENT_ALERTS_EMAIL_SMTP_PASSWORD=

# From-address used for admin email alerts.
# string
INCIDENT_ALERTS_EMAIL_FROM=

# Comma-separated admin recipient addresses for incident alert emails.
# comma-separated values
INCIDENT_ALERTS_EMAIL_TO=

##############################################################################
# 11) OBSERVABILITY/TRACING
##############################################################################

# VoltOps project public key used for optional backend observability tracing.
# string
VOLTAGENT_PUBLIC_KEY=

# VoltOps project secret key used for optional backend observability tracing.
# string
VOLTAGENT_SECRET_KEY=

# Enables metadata-only Langfuse observability mirroring from backend trace writes.
# `true` or `false`
LANGFUSE_METADATA_MIRROR_ENABLED=false

# Langfuse base URL used for metadata mirror export (for example https://cloud.langfuse.com).
# string
LANGFUSE_METADATA_MIRROR_BASE_URL=

# Langfuse public key used for Basic Auth on metadata mirror export.
# string
LANGFUSE_METADATA_MIRROR_PUBLIC_KEY=

# Langfuse secret key used for Basic Auth on metadata mirror export.
# string
LANGFUSE_METADATA_MIRROR_SECRET_KEY=

# HTTP timeout budget in milliseconds for metadata mirror export to Langfuse.
# integer
LANGFUSE_METADATA_MIRROR_TIMEOUT_MS=1500

##############################################################################
# 12) ADVANCED/EXPERIMENTAL CONTROLS
##############################################################################

# Allows the bot to reply in thread contexts by default.
# `true` or `false`
# On Fly deploy: Discord bot machine.
ALLOW_THREAD_RESPONSES=true

# Comma-separated thread IDs allowed when thread replies are restricted.
# comma-separated values
# On Fly deploy: Discord bot machine.
ALLOWED_THREAD_IDS=

# Maximum bot-to-bot message exchanges allowed before intervention.
# integer
# On Fly deploy: Discord bot machine.
BOT_BACK_AND_FORTH_LIMIT=2

# Cooldown after a bot-to-bot loop limit is reached.
# integer
# On Fly deploy: Discord bot machine.
BOT_BACK_AND_FORTH_COOLDOWN_MS=300000

# Conversation TTL for tracking bot-to-bot exchanges.
# integer
# On Fly deploy: Discord bot machine.
BOT_BACK_AND_FORTH_TTL_MS=600000

# Action to take when the bot interaction limit is reached.
# `ignore`, `react`
# On Fly deploy: Discord bot machine.
BOT_BACK_AND_FORTH_ACTION=react

# Emoji reaction used when bot interaction limit mode is react.
# string
# On Fly deploy: Discord bot machine.
BOT_BACK_AND_FORTH_REACTION=👀

# Minimum engagement score required before answering a bot-authored direct mention or reply.
# number
# On Fly deploy: Discord bot machine.
BOT_DIRECT_INVOCATION_MIN_THRESHOLD=0.75

# Messages included after the last seen message in catch-up mode.
# integer
# On Fly deploy: Discord bot machine.
CATCHUP_AFTER_MESSAGES=10

# Catch-up message count when the bot was directly mentioned.
# integer
# On Fly deploy: Discord bot machine.
CATCHUP_IF_MENTIONED_AFTER_MESSAGES=5

# TTL for stale counter tracking used by catch-up logic.
# integer
# On Fly deploy: Discord bot machine.
STALE_COUNTER_TTL_MS=3600000

# Enables in-memory channel context tracking.
# `true` or `false`
# On Fly deploy: Discord bot machine.
CONTEXT_MANAGER_ENABLED=true

# Maximum messages kept per channel in the context manager.
# integer
# On Fly deploy: Discord bot machine.
CONTEXT_MANAGER_MAX_MESSAGES=50

# Message retention window for channel context state.
# integer
# On Fly deploy: Discord bot machine.
CONTEXT_MANAGER_RETENTION_MS=3600000

# Eviction interval for stale channel context state.
# integer
# On Fly deploy: Discord bot machine.
CONTEXT_MANAGER_EVICTION_INTERVAL_MS=300000

# Enables the realtime engagement filter.
# `true` or `false`
# On Fly deploy: Discord bot machine.
REALTIME_FILTER_ENABLED=true

# Weight applied to direct mention signals.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_WEIGHT_MENTION=0.3

# Weight applied to question signals.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_WEIGHT_QUESTION=0.2

# Weight applied to technical-language signals.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_WEIGHT_TECHNICAL=0.15

# Weight applied to recent-human-activity signals.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_WEIGHT_HUMAN_ACTIVITY=0.15

# Weight applied to bot noise as a negative signal.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_WEIGHT_BOT_NOISE=0.05

# DM score multiplier used by engagement scoring.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_WEIGHT_DM_BOOST=1.5

# Time decay factor reserved for engagement scoring.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_WEIGHT_DECAY=0.05

# How the bot acknowledges skipped engagement decisions.
# `silent`, `react`
# On Fly deploy: Discord bot machine.
ENGAGEMENT_IGNORE_MODE=silent

# Emoji reaction used when engagement ignore mode is react.
# string
# On Fly deploy: Discord bot machine.
ENGAGEMENT_REACTION_EMOJI=👍

# Minimum engagement score required before responding.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_MIN_THRESHOLD=0.5

# Lower bound of the LLM-refinement grey band.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_PROBABILISTIC_LOW=0.4

# Upper bound of the LLM-refinement grey band.
# number
# On Fly deploy: Discord bot machine.
ENGAGEMENT_PROBABILISTIC_HIGH=0.6

# Enables the optional engagement refinement pass.
# `true` or `false`
# On Fly deploy: Discord bot machine.
ENGAGEMENT_ENABLE_LLM_REFINEMENT=false

# Enables verbose context logging in the Discord bot.
# `true` or `false`
# On Fly deploy: Discord bot machine.
DISCORD_BOT_LOG_FULL_CONTEXT=false

# Default text model used by image prompting flows.
# string
# On Fly deploy: Discord bot machine.
IMAGE_DEFAULT_TEXT_MODEL=gpt-4.1-mini

# Default image render model.
# string
# On Fly deploy: Discord bot machine.
IMAGE_DEFAULT_IMAGE_MODEL=gpt-image-1-mini

# Default image quality preset.
# `low`, `medium`, `high`, `auto`
# On Fly deploy: Discord bot machine.
IMAGE_DEFAULT_QUALITY=low

# Default image output format.
# `png`, `webp`, `jpeg`
# On Fly deploy: Discord bot machine.
IMAGE_DEFAULT_OUTPUT_FORMAT=png

# Default output compression for generated images.
# integer
# On Fly deploy: Discord bot machine.
IMAGE_DEFAULT_OUTPUT_COMPRESSION=100

# Maximum prompt length allowed for image generation input/storage policy. Values above 8000 are clamped to 8000 by runtime config parsing (with a warning log).
# integer
# On Fly deploy: Discord bot machine.
IMAGE_PROMPT_MAX_INPUT_CHARS=8000

# Token allowance granted each image refresh interval.
# integer
# On Fly deploy: Discord bot machine.
IMAGE_TOKENS_PER_REFRESH=10

# Refresh interval for replenishing image tokens.
# integer
# On Fly deploy: Discord bot machine.
IMAGE_TOKEN_REFRESH_INTERVAL_MS=86400000

# JSON object with model-specific image token multipliers.
# JSON
# On Fly deploy: Discord bot machine.
IMAGE_MODEL_MULTIPLIERS={"gpt-image-1-mini":1,"gpt-image-1":2,"gpt-image-1.5":2}

# Per-model image multiplier override using IMAGE_MODEL_MULTIPLIER_<MODEL_NAME> naming.
# number
# On Fly deploy: Discord bot machine.
IMAGE_MODEL_MULTIPLIER_GPT_IMAGE_1=2

# Per-model image multiplier override using IMAGE_MODEL_MULTIPLIER_<MODEL_NAME> naming.
# number
# On Fly deploy: Discord bot machine.
IMAGE_MODEL_MULTIPLIER_GPT_IMAGE_1_MINI=1

# Per-model image multiplier override using IMAGE_MODEL_MULTIPLIER_<MODEL_NAME> naming.
# number
# On Fly deploy: Discord bot machine.
IMAGE_MODEL_MULTIPLIER_GPT_IMAGE_1_5=2

# Cloudinary cloud name used for image uploads.
# string
# On Fly deploy: Discord bot machine.
CLOUDINARY_CLOUD_NAME=

# Cloudinary API key used for image uploads.
# string
# On Fly deploy: Discord bot machine.
CLOUDINARY_API_KEY=

# Cloudinary API secret used for image uploads.
# string
# On Fly deploy: Discord bot machine.
CLOUDINARY_API_SECRET=

# Enables advisory Execution Contract TrustGraph retrieval integration.
# `true` or `false`
EXECUTION_CONTRACT_TRUSTGRAPH_ENABLED=false

# Emergency kill switch for external TrustGraph retrieval while preserving local chat behavior.
# `true` or `false`
EXECUTION_CONTRACT_TRUSTGRAPH_KILL_SWITCH=false

# Policy ID sent to TrustGraph adapters for advisory retrieval scope decisions.
# string
EXECUTION_CONTRACT_TRUSTGRAPH_POLICY_ID=server_chat_runtime_policy

# Timeout budget in milliseconds for TrustGraph advisory retrieval calls.
# integer
EXECUTION_CONTRACT_TRUSTGRAPH_TIMEOUT_MS=800

# Maximum number of TrustGraph advisory retrieval calls per request.
# integer
EXECUTION_CONTRACT_TRUSTGRAPH_MAX_CALLS=1

# Adapter mode for TrustGraph retrieval integration (`none`, `stub`, or `http`).
# `none`, `stub`, `http`
EXECUTION_CONTRACT_TRUSTGRAPH_ADAPTER_MODE=none

# Stub adapter response mode used for local or test TrustGraph wiring.
# `success`, `failure`, `timeout`, `poisoned`
EXECUTION_CONTRACT_TRUSTGRAPH_STUB_ADAPTER_MODE=success

# HTTP endpoint URL for TrustGraph adapter mode when adapter mode is `http`.
# string
EXECUTION_CONTRACT_TRUSTGRAPH_ADAPTER_ENDPOINT_URL=

# Optional API token sent to the TrustGraph adapter when using HTTP mode.
# string
EXECUTION_CONTRACT_TRUSTGRAPH_ADAPTER_API_TOKEN=

# Optional adapter configuration reference passed with TrustGraph HTTP calls.
# string
EXECUTION_CONTRACT_TRUSTGRAPH_ADAPTER_CONFIG_REF=

# Ownership binding mode used by TrustGraph tenancy checks (`none` or `http`).
# `none`, `http`
EXECUTION_CONTRACT_TRUSTGRAPH_OWNERSHIP_BINDING_MODE=none

# Ownership validator ID used when TrustGraph ownership binding is active.
# string
EXECUTION_CONTRACT_TRUSTGRAPH_OWNERSHIP_VALIDATOR_ID=backend_tenancy_http_v1

# HTTP ownership validator endpoint URL used when ownership binding mode is `http`.
# string
EXECUTION_CONTRACT_TRUSTGRAPH_OWNERSHIP_ENDPOINT_URL=

# Optional API token used by the TrustGraph ownership validator endpoint.
# string
EXECUTION_CONTRACT_TRUSTGRAPH_OWNERSHIP_API_TOKEN=
