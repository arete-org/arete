{
    "snippets": {
        "footnote-risk-header": {
            "prefix": "footnote-risk",
            "body": [
                "/**",
                " * @description: ${1:1-3 lines summarizing what this module does.}",
                " * @footnote-scope: ${2|core,utility,interface,web,test|}",
                " * @footnote-module: ${3:ModuleName}",
                " * @footnote-risk: ${4|low,medium,high|} - ${5:Technical blast radius if mishandled.}",
                " * @footnote-ethics: ${6|low,medium,high|} - ${7:Human or governance impact if this behaves incorrectly.}",
                " */"
            ],
            "description": "Footnote module header template (current required format)"
        },
        "footnote-logger": {
            "prefix": "footnote-log",
            "body": [
                "logger.${1|debug,info,warn,error|}('${2:message}', { ${3:context} });"
            ],
            "description": "Footnote structured logging"
        },
        "footnote-cost-tracking": {
            "prefix": "footnote-cost",
            "body": [
                "ChannelContextManager.recordLLMUsage(${1:tokens}, ${2:cost});"
            ],
            "description": "Footnote cost tracking"
        },
        "footnote-error-handling": {
            "prefix": "footnote-try",
            "body": [
                "try {",
                "  ${1:// risky operation}",
                "} catch (error) {",
                "  logger.error('${2:Operation failed}:', error);",
                "  ${3:// error handling}",
                "}"
            ],
            "description": "Footnote error handling pattern"
        },
        "footnote-interface": {
            "prefix": "footnote-interface",
            "body": [
                "export interface ${1:InterfaceName} {",
                "  ${2:property}: ${3:type};",
                "}"
            ],
            "description": "Footnote interface template"
        }
    }
}
