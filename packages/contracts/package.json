{
    "name": "@footnote/contracts",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./ethics-core": {
            "types": "./dist/ethics-core/index.d.ts",
            "default": "./dist/ethics-core/index.js"
        },
        "./web": {
            "types": "./dist/web/index.d.ts",
            "default": "./dist/web/index.js"
        },
        "./web/client-core": {
            "types": "./dist/web/client-core.d.ts",
            "default": "./dist/web/client-core.js"
        },
        "./web/schemas": {
            "types": "./dist/web/schemas.d.ts",
            "default": "./dist/web/schemas.js"
        },
        "./voice": {
            "types": "./dist/voice/index.d.ts",
            "default": "./dist/voice/index.js"
        },
        "./voice/schemas": {
            "types": "./dist/voice/schemas.d.ts",
            "default": "./dist/voice/schemas.js"
        },
        "./providers": {
            "types": "./dist/providers.d.ts",
            "default": "./dist/providers.js"
        },
        "./pricing": {
            "types": "./dist/pricing.d.ts",
            "default": "./dist/pricing.js"
        }
    },
    "scripts": {
        "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
        "build:dev": "tsc -p tsconfig.json",
        "build": "pnpm clean && tsc -p tsconfig.json"
    },
    "dependencies": {
        "zod": "catalog:"
    }
}
