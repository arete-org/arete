{
    "name": "@footnote/config-spec",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
        "build:dev": "pnpm --dir ../.. --filter @footnote/contracts run build:dev && tsc -p tsconfig.json",
        "build": "pnpm --dir ../.. --filter @footnote/contracts run build && pnpm clean && tsc -p tsconfig.json"
    },
    "dependencies": {
        "@footnote/contracts": "workspace:*"
    }
}
